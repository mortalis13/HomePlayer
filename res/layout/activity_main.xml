<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:background="@color/main_background"
>
  
  <!-- =========== Title =========== -->
  <RelativeLayout
    android:id="@+id/panelTitle"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:focusable="true"
    android:gravity="center_vertical"
    android:background="@color/title_background"
  >
    <org.mortalis.homeplayer.components.TitleScrollView
      android:id="@+id/titleScroller"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:fillViewport="true"
      android:scrollbars="none"
      android:overScrollMode="never"
      android:measureAllChildren="false"
      android:gravity="center_vertical"
      android:smoothScrollbar="false"
      android:layout_alignParentLeft="true"
    >
      <TextView
        android:id="@+id/activeTitle"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical"
        android:textStyle="bold"
        android:textSize="20dp"
        android:textColor="#777"
      />
    </org.mortalis.homeplayer.components.TitleScrollView>
  </RelativeLayout>
  
  
  <!-- =========== Progress =========== -->
  <LinearLayout
    android:id="@+id/panelProgress"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
  >
    <org.mortalis.homeplayer.components.SliderView
      android:id="@+id/progressSlider"
      android:layout_width="match_parent"
      android:layout_height="@dimen/plain_slider_height"
    />
  </LinearLayout>
  
  
  <!-- =========== Time =========== -->
  <LinearLayout
    android:id="@+id/panelTimeInfo"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_alignParentBottom="false"
  >
    <LinearLayout
      android:id="@+id/panelInfoLeft"
      android:orientation="vertical"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:paddingLeft="6dp"
      android:background="@drawable/control_button_background"
    >
      <TextView
        android:id="@+id/textTimePlaying"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:textSize="20dp"
        android:textColor="#777"
      />
      <TextView
        android:id="@+id/textCurrentFolderTime"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:textSize="20dp"
        android:textColor="#777"
      />
    </LinearLayout>
  
    <LinearLayout
      android:id="@+id/panelInfoCenter"
      android:orientation="vertical"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:background="@drawable/control_button_background"
    >
      <TextView
        android:id="@+id/textTimeLeft"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:paddingLeft="-7dp"
        android:gravity="center"
        android:textSize="20dp"
        android:textColor="#777"
      />
      <TextView
        android:id="@+id/textPlayingStats"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:textSize="20dp"
        android:textColor="#777"
      />
    </LinearLayout>
  
    <LinearLayout
      android:id="@+id/panelInfoRight"
      android:orientation="vertical"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:paddingRight="6dp"
      android:background="@drawable/control_button_background"
    >
      <TextView
        android:id="@+id/textTimeTotal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical|right"
        android:textSize="20dp"
        android:textColor="#777"
      />
      <TextView
        android:id="@+id/textPlayingFolderTime"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical|right"
        android:textSize="20dp"
        android:textColor="#777"
      />
    </LinearLayout>
  </LinearLayout>

  <include layout="@layout/divider_horizontal_include"/>
  
  
  <!-- =========== Controls =========== -->
  <LinearLayout
    android:id="@+id/controlsPanel"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="64dp"
  >
    <ImageButton
      android:id="@+id/bPrevFile"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/baseline_navigate_before_black_36"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
    <ImageButton
      android:id="@+id/bFastRewind"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/outline_fast_rewind_black_24"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
    <FrameLayout
      android:id="@+id/iconContainer"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:gravity="center"
    >
      <ImageButton
        android:id="@+id/bPlayPause"
        android:layout_width="120dp"
        android:layout_height="match_parent"
        android:src="@drawable/baseline_play_arrow_black_36"
        android:tint="#777"
        android:background="@drawable/control_button_background"
      />
      <LinearLayout
        android:layout_width="120dp"
        android:layout_height="match_parent"
      >
        <RelativeLayout
          android:layout_width="0dp"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:paddingLeft="16dp"
          android:paddingTop="6dp"
        >
          <ImageView
            android:id="@+id/playExtraIconShuffle"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:tint="#788c94"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:src="@drawable/round_shuffle_black_18"
            android:visibility="gone"
          />
        </RelativeLayout>
        <RelativeLayout
          android:layout_width="0dp"
          android:layout_height="match_parent"
          android:layout_weight="1"
          android:paddingRight="16dp"
          android:paddingTop="6dp"
        >
          <ImageView
            android:id="@+id/playExtraIconRepeat"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:tint="#788c94"
            android:layout_alignParentRight="true"
            android:layout_alignParentTop="true"
            android:src="@drawable/round_repeat_black_18"
            android:visibility="gone"
          />
        </RelativeLayout>
      </LinearLayout>
    </FrameLayout>
    <ImageButton
      android:id="@+id/bFastForward"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/outline_fast_forward_black_24"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
    <ImageButton
      android:id="@+id/bNextFile"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/baseline_navigate_next_black_36"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
  </LinearLayout>
  
  <include layout="@layout/divider_horizontal_include"/>
  <include layout="@layout/divider_horizontal_include"/>
  
  
  <FrameLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
  >
    <!-- =========== File browser =========== -->
    <org.mortalis.homeplayer.components.BrowserRecyclerView
      android:id="@+id/listItems"
      android:scrollbars="vertical"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
    />
    
    
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
    >
    <!-- =========== Extra controls =========== -->
    <RelativeLayout
      android:id="@+id/extraPanel"
      android:layout_width="match_parent"
      android:layout_height="60dp"
      android:visibility="gone"
      android:background="@color/secondary_background"
    >
      <ImageButton
        android:id="@+id/bShuffle"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:src="@drawable/round_shuffle_black_24"
        android:tint="#777"
        android:background="@drawable/secondary_toggle_button_background"
        android:layout_alignParentLeft="true"
      />
      <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="#aaa"
        android:layout_alignParentLeft="true"
      />
      
      <ImageButton
        android:id="@+id/bRepeat"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:src="@drawable/round_repeat_black_24"
        android:tint="#777"
        android:background="@drawable/secondary_toggle_button_background"
        android:layout_alignParentRight="true"
      />
      <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="#aaa"
        android:layout_alignParentRight="true"
      />
      
      <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#aaa"
        android:layout_alignParentBottom="true"
      />
    </RelativeLayout>
    
    
    <!-- =========== Extra info =========== -->
    <ScrollView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:fillViewport="true"
    >
    <LinearLayout
      android:id="@+id/extraInfo"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:paddingTop="4dp"
      android:orientation="vertical"
      android:visibility="gone"
      android:background="@color/secondary_background"
    >
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/extra_info_row_min_height"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/extra_info_row_padding"
        android:paddingRight="@dimen/extra_info_row_padding"
      >
      <TextView
        android:layout_width="@dimen/extra_info_caption_width"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#555"
        android:text="File:"
      />
      <TextView
        android:id="@+id/textExtraFileName"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textColor="#555"
      />
      </LinearLayout>
      
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/extra_info_row_min_height"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/extra_info_row_padding"
        android:paddingRight="@dimen/extra_info_row_padding"
      >
      <TextView
        android:layout_width="@dimen/extra_info_caption_width"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#555"
        android:text="Title:"
      />
      <TextView
        android:id="@+id/textExtraTitle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textColor="#555"
      />
      </LinearLayout>
      
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/extra_info_row_min_height"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/extra_info_row_padding"
        android:paddingRight="@dimen/extra_info_row_padding"
      >
      <TextView
        android:layout_width="@dimen/extra_info_caption_width"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#555"
        android:text="Artist:"
      />
      <TextView
        android:id="@+id/textExtraArtist"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textColor="#555"
      />
      </LinearLayout>
      
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/extra_info_row_min_height"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/extra_info_row_padding"
        android:paddingRight="@dimen/extra_info_row_padding"
      >
      <TextView
        android:layout_width="@dimen/extra_info_caption_width"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#555"
        android:text="Album:"
      />
      <TextView
        android:id="@+id/textExtraAlbum"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textColor="#555"
      />
      </LinearLayout>
      
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/extra_info_row_min_height"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/extra_info_row_padding"
        android:paddingRight="@dimen/extra_info_row_padding"
      >
      <TextView
        android:layout_width="@dimen/extra_info_caption_width"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#555"
        android:text="Year:"
      />
      <TextView
        android:id="@+id/textExtraYear"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textColor="#555"
      />
      </LinearLayout>
      
      
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="@dimen/extra_info_row_min_height"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/extra_info_row_padding"
        android:paddingRight="@dimen/extra_info_row_padding"
      >
      <TextView
        android:layout_width="@dimen/extra_info_caption_width"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#777"
        android:text="Length:"
      />
      <TextView
        android:id="@+id/textExtraLength"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textColor="#777"
      />
      </LinearLayout>
      
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/extra_info_row_min_height"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/extra_info_row_padding"
        android:paddingRight="@dimen/extra_info_row_padding"
      >
      <TextView
        android:layout_width="@dimen/extra_info_caption_width"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#777"
        android:text="Bitrate:"
      />
      <TextView
        android:id="@+id/textExtraBitrate"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textColor="#777"
      />
      </LinearLayout>
      
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/extra_info_row_min_height"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/extra_info_row_padding"
        android:paddingRight="@dimen/extra_info_row_padding"
      >
      <TextView
        android:layout_width="@dimen/extra_info_caption_width"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#777"
        android:text="Frequency:"
      />
      <TextView
        android:id="@+id/textExtraFrequency"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textColor="#777"
      />
      </LinearLayout>
      
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/extra_info_row_min_height"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/extra_info_row_padding"
        android:paddingRight="@dimen/extra_info_row_padding"
      >
      <TextView
        android:layout_width="@dimen/extra_info_caption_width"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#777"
        android:text="Channels:"
      />
      <TextView
        android:id="@+id/textExtraChannels"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textColor="#777"
      />
      </LinearLayout>
      
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/extra_info_row_min_height"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/extra_info_row_padding"
        android:paddingRight="@dimen/extra_info_row_padding"
      >
      <TextView
        android:layout_width="@dimen/extra_info_caption_width"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#777"
        android:text="Size:"
      />
      <TextView
        android:id="@+id/textExtraSize"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textColor="#777"
      />
      </LinearLayout>
      
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:minHeight="@dimen/extra_info_row_min_height"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/extra_info_row_padding"
        android:paddingRight="@dimen/extra_info_row_padding"
      >
      <TextView
        android:layout_width="@dimen/extra_info_caption_width"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textStyle="bold"
        android:textColor="#777"
        android:text="Path:"
      />
      <TextView
        android:id="@+id/textExtraPath"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textSize="18dp"
        android:textColor="#777"
      />
      </LinearLayout>
      
      <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#aaa"
      />
    </LinearLayout>
    <!-- extraInfo -->
    </ScrollView>
    
    </LinearLayout>
    <!-- All extras -->
    
  </FrameLayout>

</LinearLayout>
