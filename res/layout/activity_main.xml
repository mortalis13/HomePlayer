<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:background="@color/main_background"
>
  
  <RelativeLayout
    android:id="@+id/panelTitle"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:focusable="true"
    android:gravity="center_vertical"
    android:background="@color/title_background"
  >
    <org.mortalis.homeplayer.components.TitleScrollView
      android:id="@+id/titleScroller"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:fillViewport="true"
      android:scrollbars="none"
      android:overScrollMode="never"
      android:measureAllChildren="false"
      android:gravity="center_vertical"
      android:smoothScrollbar="false"
      android:layout_alignParentLeft="true"
    >
      <TextView
        android:id="@+id/activeTitle"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical"
        android:textStyle="bold"
        android:textSize="20dp"
        android:textColor="#777"
      />
    </org.mortalis.homeplayer.components.TitleScrollView>
  </RelativeLayout>
  
  <LinearLayout
    android:id="@+id/panelProgress"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
  >
    <org.mortalis.homeplayer.components.SliderView
      android:id="@+id/progressSlider"
      android:layout_width="match_parent"
      android:layout_height="@dimen/plain_slider_height"
    />
  </LinearLayout>
  
  
  <LinearLayout
    android:id="@+id/panelTimeInfo"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_alignParentBottom="false"
  >
    <LinearLayout
      android:id="@+id/panelInfoLeft"
      android:orientation="vertical"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:paddingLeft="6dp"
      android:background="@drawable/control_button_background"
    >
      <TextView
        android:id="@+id/textTimePlaying"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:textSize="20dp"
        android:textColor="#777"
      />
      <TextView
        android:id="@+id/textCurrentFolderTime"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:textSize="20dp"
        android:textColor="#777"
      />
    </LinearLayout>
  
    <LinearLayout
      android:id="@+id/panelInfoCenter"
      android:orientation="vertical"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:background="@drawable/control_button_background"
    >
      <TextView
        android:id="@+id/textTimeLeft"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:paddingLeft="-7dp"
        android:gravity="center"
        android:textSize="20dp"
        android:textColor="#777"
      />
      <TextView
        android:id="@+id/textPlayingStats"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:textSize="20dp"
        android:textColor="#777"
      />
    </LinearLayout>
  
    <LinearLayout
      android:id="@+id/panelInfoRight"
      android:orientation="vertical"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:paddingRight="6dp"
      android:background="@drawable/control_button_background"
    >
      <TextView
        android:id="@+id/textTimeTotal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical|right"
        android:textSize="20dp"
        android:textColor="#777"
      />
      <TextView
        android:id="@+id/textPlayingFolderTime"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical|right"
        android:textSize="20dp"
        android:textColor="#777"
      />
    </LinearLayout>
  </LinearLayout>

  <include layout="@layout/divider_horizontal_include"/>
  
  <LinearLayout
    android:id="@+id/controlsPanel"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="64dp"
  >
    <ImageButton
      android:id="@+id/bPrevFile"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/baseline_navigate_before_black_36"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
    <ImageButton
      android:id="@+id/bFastRewind"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/outline_fast_rewind_black_24"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
    <ImageButton
      android:id="@+id/bPlayPause"
      android:layout_width="120dp"
      android:layout_height="match_parent"
      android:src="@drawable/baseline_play_arrow_black_36"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
    <ImageButton
      android:id="@+id/bFastForward"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/outline_fast_forward_black_24"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
    <ImageButton
      android:id="@+id/bNextFile"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/baseline_navigate_next_black_36"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
  </LinearLayout>
  
  <include layout="@layout/divider_horizontal_include"/>
  <include layout="@layout/divider_horizontal_include"/>
  
  <FrameLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
  >
    <org.mortalis.homeplayer.components.BrowserRecyclerView
      android:id="@+id/listItems"
      android:scrollbars="vertical"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
    />
    
    <RelativeLayout
      android:id="@+id/extraPanel"
      android:layout_width="match_parent"
      android:layout_height="60dp"
      android:visibility="gone"
      android:background="@color/secondary_background"
    >
      <ImageButton
        android:id="@+id/bShuffle"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:src="@drawable/round_shuffle_black_24"
        android:tint="#777"
        android:background="@drawable/secondary_toggle_button_background"
        android:layout_alignParentLeft="true"
      />
      <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="#aaa"
        android:layout_alignParentLeft="true"
      />
      
      <ImageButton
        android:id="@+id/bRepeat"
        android:layout_width="60dp"
        android:layout_height="match_parent"
        android:src="@drawable/round_repeat_black_24"
        android:tint="#777"
        android:background="@drawable/secondary_toggle_button_background"
        android:layout_alignParentRight="true"
      />
      <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="#aaa"
        android:layout_alignParentRight="true"
      />
      
      <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#aaa"
        android:layout_alignParentBottom="true"
      />
    </RelativeLayout>
  </FrameLayout>

</LinearLayout>
