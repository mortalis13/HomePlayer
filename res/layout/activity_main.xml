<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:background="@color/main_background"
>
  <RelativeLayout
    android:id="@+id/panelTitle"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:focusable="true"
    android:gravity="center_vertical"
    android:background="@color/title_background"
  >
    <org.mortalis.homeplayer.components.TitleScrollView
      android:id="@+id/titleScroller"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:paddingLeft="10dp"
      android:fillViewport="true"
      android:scrollbars="none"
      android:overScrollMode="never"
      android:measureAllChildren="false"
      android:gravity="center_vertical"
      android:smoothScrollbar="false"
      android:layout_alignParentLeft="true"
      android:layout_toLeftOf="@+id/bGoBack"
    >
    <TextView
      android:id="@+id/activeTitle"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:paddingTop="4dp"
      android:paddingBottom="4dp"
      android:gravity="center_vertical"
      android:textStyle="bold"
      android:textSize="20dp"
      android:textColor="#777"
    />
    </org.mortalis.homeplayer.components.TitleScrollView>
    
    <ImageButton
      android:id="@+id/bGoBack"
      android:layout_width="50dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/round_undo_black_24"
      android:tint="#777"
      android:background="@drawable/control_button_background"
      android:layout_alignParentRight="true"
    />
  </RelativeLayout>
  
  <LinearLayout
    android:id="@+id/panelProgress"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
  >
    <org.mortalis.homeplayer.components.SliderView
      android:id="@+id/progressSlider"
      android:layout_width="match_parent"
      android:layout_height="@dimen/plain_slider_height"
    />
  </LinearLayout>
  
  <RelativeLayout
    android:id="@+id/panelTimeInfo"
    android:layout_width="match_parent"
    android:layout_height="24dp"
    android:paddingLeft="6dp"
    android:paddingRight="6dp"
    android:gravity="center_vertical"
  >
    <TextView
      android:id="@+id/textTimePlaying"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:gravity="center_vertical"
      android:textSize="20dp"
      android:textColor="#777"
      android:layout_alignParentLeft="true"
    />
    <TextView
      android:id="@+id/textTimeLeft"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:gravity="center_vertical"
      android:textSize="20dp"
      android:textColor="#777"
      android:layout_centerHorizontal="true"
    />
    <TextView
      android:id="@+id/textTimeTotal"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:gravity="center_vertical"
      android:textSize="20dp"
      android:textColor="#777"
      android:layout_alignParentRight="true"
    />
  </RelativeLayout>
  
  <RelativeLayout
    android:id="@+id/panelStats"
    android:layout_width="match_parent"
    android:layout_height="24dp"
    android:paddingLeft="6dp"
    android:paddingRight="6dp"
    android:layout_marginBottom="3dp"
    android:gravity="center_vertical"
  >
    <TextView
      android:id="@+id/textCurrentFolderStats"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:paddingRight="6dp"
      android:gravity="center_vertical"
      android:textSize="20dp"
      android:textColor="#777"
      android:layout_alignParentLeft="true"
    />
    <TextView
      android:id="@+id/textCurrentFolderTime"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:paddingLeft="6dp"
      android:paddingRight="6dp"
      android:gravity="center_vertical"
      android:textSize="20dp"
      android:textColor="#777"
      android:layout_toRightOf="@+id/textCurrentFolderStats"
    />
    
    <TextView
      android:id="@+id/textPlayingStats"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:paddingLeft="6dp"
      android:paddingRight="6dp"
      android:gravity="center_vertical"
      android:textSize="20dp"
      android:textColor="#777"
      android:layout_toLeftOf="@+id/textPlayingFolderTime"
    />
    <TextView
      android:id="@+id/textPlayingFolderTime"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:paddingLeft="6dp"
      android:gravity="center_vertical"
      android:textSize="20dp"
      android:textColor="#777"
      android:layout_alignParentRight="true"
    />
  </RelativeLayout>
  
  <include layout="@layout/divider_horizontal_include"/>
  
  <LinearLayout
    android:id="@+id/controlsPanel"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_alignParentBottom="false"
  >
    <ImageButton
      android:id="@+id/bPrevFile"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/baseline_navigate_before_black_36"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
    <ImageButton
      android:id="@+id/bPlayPause"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/baseline_play_arrow_black_36"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
    <ImageButton
      android:id="@+id/bNextFile"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:src="@drawable/baseline_navigate_next_black_36"
      android:tint="#777"
      android:background="@drawable/control_button_background"
    />
  </LinearLayout>
  
  <include layout="@layout/divider_horizontal_include"/>
  <include layout="@layout/divider_horizontal_include"/>
  
  <org.mortalis.homeplayer.components.BrowserRecyclerView
    android:id="@+id/listItems"
    android:scrollbars="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
  />
</LinearLayout>
