<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:descendantFocusability="blocksDescendants"
  android:background="@color/list_item_background"
>

<FrameLayout
  android:layout_width="match_parent"
  android:layout_height="match_parent"
>
  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:minHeight="64dp"
    android:gravity="center_vertical"
  >
    <FrameLayout
      android:id="@+id/iconContainer"
      android:layout_width="46dp"
      android:layout_height="match_parent"
      android:gravity="center"
    >
      <ImageView
        android:id="@+id/itemIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:tint="?listItemIconColor"
      />
      <org.mortalis.homeplayernative.components.SimplePaintView
        android:id="@+id/itemIndicator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center_vertical"
        android:visibility="gone"
      />
    </FrameLayout>
    
    <TextView
      android:id="@+id/itemText"
      android:layout_width="0dp"
      android:layout_height="match_parent"
      android:layout_weight="1"
      android:paddingTop="2dp"
      android:paddingBottom="2dp"
      android:paddingRight="8dp"
      android:gravity="center_vertical"
      android:textColor="?primaryTextColor"
      android:textSize="18dp"
      android:focusable="true"
    />
    
    <TextView
      android:id="@+id/itemTime"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:minWidth="50dp"
      android:paddingRight="6dp"
      android:gravity="center_vertical"
      android:textColor="?primaryTextColor"
      android:textSize="16dp"
      android:focusable="true"
      android:visibility="gone"
    />
  </LinearLayout>


  <!-- Prevent accidental row clicking at the screen edge -->
  <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
  >
    <LinearLayout
      android:layout_width="4dp"
      android:layout_height="match_parent"
      android:layout_alignParentLeft="true"
      android:clickable="true"
    />
    <LinearLayout
      android:layout_width="4dp"
      android:layout_height="match_parent"
      android:layout_alignParentRight="true"
      android:clickable="true"
    />
  </RelativeLayout>
  
  
  <!-- =========== File menu =========== -->
  <RelativeLayout
    android:id="@+id/itemMenuPanel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone"
  >
    <View
      android:layout_width="1dp"
      android:layout_height="match_parent"
      android:background="?listItemSeparatorColor"
      android:layout_toLeftOf="@+id/bRemoveFile"
    />
    <ImageButton
      android:id="@+id/bRemoveFile"
      android:layout_width="70dp"
      android:layout_height="match_parent"
      android:src="@drawable/outline_highlight_off_black_24"
      android:tint="?secondaryTextColor"
      android:background="@color/list_item_button_background"
      android:layout_toLeftOf="@+id/bFileInfo"
    />
    <ImageButton
      android:id="@+id/bFileInfo"
      android:layout_width="70dp"
      android:layout_height="match_parent"
      android:src="@drawable/outline_info_black_24"
      android:tint="?secondaryTextColor"
      android:background="@color/list_item_button_background"
      android:layout_alignParentRight="true"
    />
  </RelativeLayout>

</FrameLayout>

  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:background="?listItemSeparatorColor"
    android:focusable="true"
    android:clickable="true"
  />
</LinearLayout>