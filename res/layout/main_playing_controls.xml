<merge xmlns:android="http://schemas.android.com/apk/res/android">

<LinearLayout
  android:id="@+id/controlsPanel"
  android:orientation="horizontal"
  android:layout_width="match_parent"
  android:layout_height="@dimen/playing_controls_height"
>
  <ImageButton
    android:id="@+id/bPrevFile"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:src="@drawable/baseline_navigate_before_black_36"
    android:tint="?secondaryTextColor"
    android:background="@color/control_button_background"
  />
  <ImageButton
    android:id="@+id/bFastRewind"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:src="@drawable/outline_fast_rewind_black_24"
    android:tint="?secondaryTextColor"
    android:background="@color/control_button_background"
  />
  
  <FrameLayout
    android:id="@+id/iconContainer"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:gravity="center"
  >
    <ImageButton
      android:id="@+id/bPlayPause"
      android:layout_width="@dimen/play_button_width"
      android:layout_height="match_parent"
      android:src="@drawable/baseline_play_arrow_black_36"
      android:tint="?secondaryTextColor"
      android:background="@color/control_button_background"
    />
    
    <RelativeLayout
      android:layout_width="@dimen/play_button_width"
      android:layout_height="match_parent"
    >
      <RelativeLayout
        android:layout_width="@dimen/play_button_extra_icon_size"
        android:layout_height="@dimen/play_button_extra_icon_size"
        android:layout_marginLeft="@dimen/play_button_extra_icon_horizontal_margin"
        android:layout_marginTop="@dimen/play_button_extra_icon_vertical_margin"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
      >
        <ImageView
          android:id="@+id/playExtraIconShuffle"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_gravity="center"
          android:gravity="center"
          android:tint="?extraIconTintColor"
          android:src="@drawable/round_shuffle_black_18"
          android:visibility="gone"
        />
      </RelativeLayout>
      
      <RelativeLayout
        android:layout_width="@dimen/play_button_extra_icon_size"
        android:layout_height="@dimen/play_button_extra_icon_size"
        android:layout_marginRight="@dimen/play_button_extra_icon_horizontal_margin"
        android:layout_marginTop="@dimen/play_button_extra_icon_vertical_margin"
        android:layout_alignParentRight="true"
        android:layout_alignParentTop="true"
      >
        <ImageView
          android:id="@+id/playExtraIconRepeat"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_gravity="center"
          android:gravity="center"
          android:tint="?extraIconTintColor"
          android:src="@drawable/round_repeat_black_18"
          android:visibility="gone"
        />
      </RelativeLayout>
      
      <RelativeLayout
        android:layout_width="@dimen/play_button_extra_icon_size"
        android:layout_height="@dimen/play_button_extra_icon_size"
        android:layout_marginRight="@dimen/play_button_extra_icon_horizontal_margin"
        android:layout_centerVertical="true"
        android:layout_alignParentRight="true"
      >
        <ImageView
          android:id="@+id/playExtraIconLoop"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_gravity="center"
          android:gravity="center"
          android:tint="?extraIconTintColor"
          android:src="@drawable/audio_loop_24dp"
          android:visibility="gone"
        />
      </RelativeLayout>
      
      <RelativeLayout
        android:layout_width="@dimen/play_button_extra_icon_size"
        android:layout_height="@dimen/play_button_extra_icon_size"
        android:layout_marginLeft="@dimen/play_button_extra_icon_horizontal_margin"
        android:layout_marginBottom="@dimen/play_button_extra_icon_vertical_margin"
        android:layout_alignParentLeft="true"
        android:layout_alignParentBottom="true"
      >
        <ImageView
          android:id="@+id/playExtraIconTrim"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_gravity="center"
          android:gravity="center"
          android:tint="?extraIconTintColor"
          android:src="@drawable/audio_trim_24dp"
          android:visibility="gone"
        />
      </RelativeLayout>
      
      <RelativeLayout
        android:layout_width="@dimen/play_button_extra_icon_size"
        android:layout_height="@dimen/play_button_extra_icon_size"
        android:layout_marginRight="@dimen/play_button_extra_icon_horizontal_margin"
        android:layout_marginBottom="@dimen/play_button_extra_icon_vertical_margin"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
      >
        <ImageView
          android:id="@+id/playExtraIconEQ"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_gravity="center"
          android:gravity="center"
          android:tint="?extraIconTintColor"
          android:src="@drawable/baseline_equalizer_black_24"
          android:visibility="gone"
        />
      </RelativeLayout>
    </RelativeLayout>
  </FrameLayout>
  
  <ImageButton
    android:id="@+id/bFastForward"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:src="@drawable/outline_fast_forward_black_24"
    android:tint="?secondaryTextColor"
    android:background="@color/control_button_background"
  />
  <ImageButton
    android:id="@+id/bNextFile"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:src="@drawable/baseline_navigate_next_black_36"
    android:tint="?secondaryTextColor"
    android:background="@color/control_button_background"
  />
</LinearLayout>
  
</merge>
